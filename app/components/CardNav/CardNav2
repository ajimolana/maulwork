'use client'

import React, { useLayoutEffect, useRef, useState } from 'react';
import { gsap } from 'gsap';
import { GoArrowUpRight } from 'react-icons/go';
import GlassSurface from '../GlassSurface/GlassSurface';

const hexToRgba = (hex: string, alpha: number) => {
  let cleaned = hex.replace('#', '').trim();
  if (cleaned.length === 3) {
    cleaned = cleaned.split('').map((c) => c + c).join('');
  }
  const value = parseInt(cleaned, 16);
  if (Number.isNaN(value) || cleaned.length !== 6) return `rgba(0, 0, 0, ${alpha})`;
  const r = (value >> 16) & 255;
  const g = (value >> 8) & 255;
  const b = value & 255;
  return `rgba(${r}, ${g}, ${b}, ${alpha})`;
};

type CardNavLink = {
  label: string;
  href: string;
  ariaLabel: string;
  openInNewTab?: boolean;
};

export type CardNavItem = {
  label: string;
  bgColor: string;
  textColor: string;
  links: CardNavLink[];
};

export interface CardNavProps {
  logo: string;
  logoAlt?: string;
  items: CardNavItem[];
  className?: string;
  ease?: string;
  baseColor?: string;
  menuColor?: string;
  buttonBgColor?: string;
  buttonTextColor?: string;
  title?: string;
  ctaLabel?: string;
  ctaHref?: string;
}

const CardNav: React.FC<CardNavProps> = ({
  items,
  className = '',
  ease = 'power3.out',
  title
}) => {
  const [isExpanded, setIsExpanded] = useState(false);
  const [containerWidth, setContainerWidth] = useState<number | null>(null);
  const collapsedWidthRef = useRef<number>(180);
  const containerRef = useRef<HTMLDivElement | null>(null);
  const navRef = useRef<HTMLDivElement | null>(null);
  const titleRef = useRef<HTMLButtonElement | null>(null);
  const cardsRef = useRef<HTMLDivElement[]>([]);
  const tlRef = useRef<gsap.core.Timeline | null>(null);

  const getExpandedWidth = () => Math.min(window.innerWidth * 0.9, 800);

  const measureCollapsedWidth = () => {
    if (!titleRef.current) return 180;
    // Paksa ukur lebar teks asli tanpa wrap
    const titleWidth = titleRef.current.scrollWidth;
    const extraPadding = 40;
    return Math.max(Math.ceil(titleWidth + extraPadding), 180);
  };

  const calculateHeight = () => {
    const isMobile = window.matchMedia('(max-width: 768px)').matches;
    if (isMobile) {
      const contentEl = navRef.current?.querySelector('.card-nav-content') as HTMLElement;
      return 50 + (contentEl?.scrollHeight || 0) + 10;
    }
    return 220; // Tinggi desktop yang seragam
  };

  const createTimeline = () => {
    const navEl = navRef.current;
    const containerEl = containerRef.current;
    if (!navEl || !containerEl) return null;

    gsap.set(containerEl, { width: collapsedWidthRef.current });
    gsap.set(navEl, { height: 50 });
    gsap.set(cardsRef.current, { y: 20, opacity: 0 });

    const tl = gsap.timeline({ paused: true });
    tl.to(containerEl, { width: getExpandedWidth(), duration: 0.4, ease }, 0);
    tl.to(navEl, { height: calculateHeight, duration: 0.4, ease }, 0);
    tl.to(cardsRef.current, { y: 0, opacity: 1, duration: 0.3, ease, stagger: 0.05 }, '-=0.2');

    return tl;
  };

  useLayoutEffect(() => {
    const width = measureCollapsedWidth();
    collapsedWidthRef.current = width;
    setContainerWidth(width);
    
    const tl = createTimeline();
    tlRef.current = tl;
    return () => tl?.kill();
  }, [title, items]);

  const toggleMenu = () => {
    if (!tlRef.current) return;
    if (!isExpanded) {
      setIsExpanded(true);
      tlRef.current.play();
    } else {
      tlRef.current.reverse().eventCallback('onReverseComplete', () => setIsExpanded(false));
    }
  };

  return (
    <div
      ref={containerRef}
      className={`card-nav-container fixed left-1/2 -translate-x-1/2 z-[99] bottom-6 md:bottom-auto md:top-[2em] will-change-[width] ${className}`}
      style={containerWidth ? { width: `${containerWidth}px` } : undefined}
    >
      <nav
        ref={navRef}
        className="card-nav block rounded-2xl shadow-xl relative overflow-hidden border border-white/10"
      >
        {/* GLASSSURFACE KEMBALI */}
        <GlassSurface width="100%" height="100%" borderRadius={18} opacity={0.8} backgroundOpacity={0.08} className="absolute inset-0" />
        
        {/* TOP BAR / TITLE BAR */}
        <div className="card-nav-top absolute inset-x-0 bottom-0 md:bottom-auto md:top-0 h-[50px] flex items-center justify-center z-30 border-t md:border-t-0 md:border-b border-white/10 bg-[#111111]/20 backdrop-blur-sm">
            <button
              type="button"
              onClick={toggleMenu}
              // whitespace-nowrap agar tidak wrap ke 2 baris
              className="logo px-6 text-[14px] font-bold tracking-wide text-white cursor-pointer whitespace-nowrap outline-none"
              ref={titleRef}
            >
              {title}
            </button>
        </div>

        {/* MENU CONTENT */}
        <div
          className={`card-nav-content absolute left-0 right-0 bottom-[50px] md:bottom-0 md:top-[50px] p-2 md:p-3 flex flex-col md:flex-row items-stretch gap-2 z-20 ${
            isExpanded ? 'visible pointer-events-auto' : 'invisible pointer-events-none'
          }`}
        >
          {(items || []).slice(0, 3).map((item, idx) => (
            <div
              key={idx}
              ref={(el) => { if (el) cardsRef.current[idx] = el; }}
              className="nav-card relative flex flex-col flex-1 min-w-0"
            >
              <div
                className="w-full h-full rounded-xl p-4 flex flex-col justify-between shadow-inner"
                style={{ backgroundColor: hexToRgba('#1b1e23', 0.85) }}
              >
                {/* Label Atas: Sejajar */}
                <div className="nav-card-label font-semibold text-[15px] md:text-[17px] text-white/40 uppercase tracking-tighter">
                  {item.label}
                </div>
                
                {/* Links Bawah: Sejajar (Bottom-Heavy) */}
                <div className="nav-card-links mt-4 flex flex-col gap-1.5">
                  {item.links?.map((lnk, i) => (
                    <a
                      key={i}
                      className="nav-card-link inline-flex items-center gap-2 text-white hover:text-[#C6F10E] transition-all text-[14px] md:text-[15px] font-medium group"
                      href={lnk.href}
                      target={lnk.openInNewTab ? "_blank" : undefined}
                    >
                      <GoArrowUpRight className="shrink-0 opacity-40 group-hover:opacity-100 group-hover:translate-x-0.5 transition-transform" />
                      <span className="whitespace-nowrap">{lnk.label}</span>
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>
      </nav>
    </div>
  );
};

export default CardNav;
